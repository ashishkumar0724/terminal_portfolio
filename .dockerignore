# ============================================
# Docker Ignore File
# Files to exclude from Docker build context
# ============================================

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# Next.js build output
.next
out
build
dist

# Environment files (copy .env.example to .env if needed)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.idea
.vscode
*.swp
*.swo
*~

# Git
.git
.gitignore

# Docker files (don't include in build context)
Dockerfile
Dockerfile.dev
docker-compose*.yml
.dockerignore

# Documentation
README.md
CHANGELOG.md
LICENSE
docs/

# Test files
coverage
.nyc_output
*.test.ts
*.test.js
*.spec.ts
*.spec.js
__tests__
__mocks__

# Misc
.DS_Store
Thumbs.db
*.log
*.pid
*.seed
*.pid.lock

# Development files
.eslintrc*
.prettierrc*
jest.config.*
playwright.config.*

# Prisma generated files (if using database)
# prisma/generated

# Temporary files
tmp
temp
.cache
